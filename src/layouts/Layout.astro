---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Astro Review" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="dark:bg-gray-900 bg-gray-200 dark:text-white text-gray-900 container m-auto max-w-4xl px-5 my-10"
  >
    <slot />
  </body>
</html>
