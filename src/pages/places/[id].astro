---
import type { GetStaticPaths } from "astro";
import { actions } from "astro:actions";
import Layout from "../../layouts/Layout.astro";
import Star from "../../components/Star.astro";
import { Image } from "astro:assets";
import type { Place } from "../../generated/prisma/client";

interface Props {
  place: Place;
}
import prisma from "../../lib/prisma";
import Availability from "../../components/Availability.astro";

export const getStaticPaths = async () => {
  const places = await prisma.place.findMany();

  return places.map((place) => ({
    params: { id: String(place.id) },
    props: { place },
  }));
};

const { place } = Astro.props;

if (!place) {
  throw new Error("no place found");
}
const { id } = Astro.params;

const imageUrl = `/assets/images/${place.image}`;
---

<Layout title={`${place.title} — Astro Server Islands`}>
  <div class="detail-page">
    <!-- Back -->
    <a href="/" class="detail-back">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5" />
        <path d="M12 19l-7-7 7-7" />
      </svg>
      Volver a todos los lugares
    </a>

    <!-- Detail Card -->
    <div class="detail-content animate-in">
      <div class="detail-image-wrapper">
        <Image
          src={imageUrl}
          alt={place.title}
          width={600}
          height={600}
        />
      </div>

      <div class="detail-info">
        <span class="detail-id">Lugar #{place.id}</span>
        <h1 class="detail-title">{place.title}</h1>
        <p class="detail-description">{place.description}</p>

        <div class="detail-rating">
          <div class="place-card-stars">
            {Array.from({ length: Number(place.avg_rating) }).map(() => <Star />)}
          </div>
          <span class="rating-badge">{place.avg_rating}</span>
        </div>

        <!-- Availability (Server Island) -->
        <Availability placeId={place.id.toString()} server:defer>
          <p slot="fallback" class="availability-fallback">
            🏝️ Cargando Server Island…
          </p>
        </Availability>
      </div>
    </div>

    <!-- Server Island Callout -->
    <div class="server-island-callout animate-in animate-delay-2">
      <div class="server-island-callout-header">
        <span>🏝️</span>
        Server Island en Acción
      </div>
      <p>
        La <strong>verificación de disponibilidad</strong> de arriba es un <strong>Server Island</strong>.
        Toda esta página fue pre-renderizada como HTML estático en tiempo de compilación, pero el
        componente de disponibilidad está marcado con <code>server:defer</code> — se renderiza en
        el servidor en tiempo de solicitud y se transmite a la página después de la carga inicial.
        Esto te da cargas de página instantáneas con datos frescos y dinámicos exactamente donde los necesitas.
      </p>
    </div>
  </div>
</Layout>
